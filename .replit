run = "npm run dev:dashboard"
entrypoint = "apps/dashboard/app/layout.tsx"

[nix]
channel = "stable-24_05"

[nix.packages]
nodejs = "22"
postgresql = "15"

[env]
NODE_ENV = "development"

[deployment]
run = ["sh", "-c", "npm install && npm run build -w @treasuryos/dashboard && npm run dev:dashboard"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80
