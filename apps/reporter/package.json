{
  "name": "@treasuryos/reporter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs watch src/main.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start:prod": "node ../../node_modules/tsx/dist/cli.mjs src/main.ts",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@treasuryos/types": "0.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}
