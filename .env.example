# ═══════════════════════════════════════════════════════════════
# TreasuryOS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env
# Then fill in the values for your target environment.
#
# Legend:
#   [REQUIRED]  Must be set — the service will refuse to start without it.
#   [OPTIONAL]  Feature-gated; the service starts without it but that
#               feature will be disabled.
#   [INJECTED]  Set automatically by the platform (Railway / Vercel).
#               Do NOT set these manually in production.
# ═══════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────
# [REQUIRED] One of: development | test | production
NODE_ENV=development

# ── API Gateway (Railway) ─────────────────────────────────────
# [INJECTED] Railway sets PORT automatically at runtime.
# [OPTIONAL] Local fallback port when PORT is not injected.
API_GATEWAY_PORT=3001

# [REQUIRED] Random secret used to sign internal auth tokens.
#            Must be at least 32 characters. Generate with:
#            openssl rand -hex 32
AUTH_TOKEN_SECRET=replace-with-a-random-32-char-secret-minimum

# [OPTIONAL] Token lifetime in minutes (default: 480 = 8 hours).
AUTH_TOKEN_TTL_MINUTES=480

# ── Database (Neon Serverless Postgres) ───────────────────────
# [REQUIRED] Pooled connection string from your Neon project.
#   Local:  postgresql://postgres:postgres@localhost:5432/treasury_os
#   Neon:   postgresql://neondb_owner:<password>@ep-<id>.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/treasury_os

# [REQUIRED in production] Enable TLS for Neon / managed Postgres.
DATABASE_SSL=false

# ── Redis / Queue (Upstash Serverless Redis) ──────────────────
# [REQUIRED] Redis connection URL.
#   Local:   redis://localhost:6379
#   Upstash: rediss://default:<token>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# [OPTIONAL] Upstash REST API — preferred for serverless/edge deployments.
#   Obtain from: Upstash Console → Database → REST API
UPSTASH_REDIS_REST_URL=https://<your-upstash-host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# [OPTIONAL] BullMQ-style event queue settings.
REDIS_QUEUE_ENABLED=true
REDIS_QUEUE_NAME=treasuryos:events

# ── CORS (Railway → Vercel) ───────────────────────────────────
# [REQUIRED in production] Set to your Vercel dashboard URL so the
# API Gateway allows cross-origin requests from the frontend.
#   Example: https://treasuryos.aicustom.net
FRONTEND_URL=http://localhost:3000

# ── Frontend → API Mapping (Vercel) ──────────────────────────
# [REQUIRED on Vercel] Server-side URL of the deployed API Gateway.
#   Set this in Vercel project settings — do NOT use NEXT_PUBLIC_.
#   Example: https://api.treasuryos.aicustombot.net/api
API_BASE_URL=http://localhost:3001/api

# ── Default Seed Users ────────────────────────────────────────
# [REQUIRED] Used by the database seed script to create initial accounts.
#            Use strong, unique passwords in production.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=<strong-admin-password-min-12-chars>
DEFAULT_COMPLIANCE_EMAIL=compliance@example.com
DEFAULT_COMPLIANCE_PASSWORD=<strong-compliance-password-min-12-chars>
DEFAULT_AUDITOR_EMAIL=auditor@example.com
DEFAULT_AUDITOR_PASSWORD=<strong-auditor-password-min-12-chars>

# ── Pilot / Institutional Config ──────────────────────────────
# [OPTIONAL] Defaults are suitable for the EU CASP pilot.
PILOT_REPORTS_DIR=data/reports
PILOT_INSTITUTION_ID=pilot-eu-casp
PILOT_INSTITUTION_NAME=TreasuryOS Pilot Institution
PILOT_CUSTOMER_PROFILE=eu-regulated-casp

# ── KYC (SumSub) ─────────────────────────────────────────────
# [OPTIONAL] Required only when KYC verification is enabled.
#   Obtain from: SumSub Dashboard → Developers → App Tokens
#   Use sandbox tokens (sbx:...) for development.
SUMSUB_APP_TOKEN=sbx:<your-sumsub-app-token>
SUMSUB_SECRET_KEY=<your-sumsub-secret-key>
SUMSUB_LEVEL_NAME=basic-kyc-level

# [OPTIONAL] Webhook HMAC secret — set in SumSub → Webhooks settings.
SUMSUB_WEBHOOK_SECRET=<your-sumsub-webhook-secret>

# ── Solana ────────────────────────────────────────────────────
# [REQUIRED] RPC endpoint for the target network.
#   Devnet:  https://api.devnet.solana.com
#   Mainnet: https://api.mainnet-beta.solana.com  (or a private RPC)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# [REQUIRED] On-chain program ID for the wallet whitelist contract.
PROGRAM_ID_WALLET_WHITELIST=<your-deployed-program-id>

# [OPTIONAL] Filesystem keypair path — local dev only.
#            In production use AWS KMS (see below).
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json
SOLANA_SIGNING_MODE=filesystem

# [OPTIONAL] Disable on-chain sync in local/dev environments.
SOLANA_SYNC_ENABLED=false

# ── AWS KMS (production signing) ─────────────────────────────
# [OPTIONAL] Required when SOLANA_SIGNING_MODE=kms.
#   Obtain from: AWS Console → KMS → Customer managed keys
# AWS_KMS_KEY_ID=<your-kms-key-id>
# AWS_KMS_PUBLIC_KEY=<your-kms-public-key>
# AWS_REGION=eu-central-1

# ── Squads Multisig ───────────────────────────────────────────
# [OPTIONAL] Enable on-chain multisig governance via Squads Protocol.
SQUADS_MULTISIG_ENABLED=false
# SQUADS_MULTISIG_ADDRESS=<your-squads-multisig-pda>

# ── Supabase ──────────────────────────────────────────────────
# [OPTIONAL] Required for Supabase Auth and document storage.
#   Obtain from: Supabase Dashboard → Settings → API
#   Use the service_role key ONLY on the server — never expose it client-side.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
SUPABASE_STORAGE_BUCKET=compliance-docs