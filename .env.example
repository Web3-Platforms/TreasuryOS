# ═══════════════════════════════════════════════════════════════
# TreasuryOS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env
# Then fill in the values for your target environment.
#
# Legend:
#   [REQUIRED]  Must be set — the service will refuse to start without it.
#   [OPTIONAL]  Feature-gated; the service starts without it but that
#               feature will be disabled.
#   [INJECTED]  Set automatically by the platform (Railway / Vercel).
#               Do NOT set these manually in production.
# ═══════════════════════════════════════════════════════════════

# ── Shared ────────────────────────────────────────────────────
NODE_ENV=<your-node-env>

# ── API Gateway (Railway) ─────────────────────────────────────
# [INJECTED] Railway sets PORT automatically at runtime.
# [OPTIONAL] Local fallback port when PORT is not injected.
API_GATEWAY_PORT=3001

# [REQUIRED] Random secret used to sign internal auth tokens.
#            Must be at least 32 characters. Generate with:
#            openssl rand -hex 32
AUTH_TOKEN_SECRET=replace-with-a-random-32-char-secret-minimum

# [OPTIONAL] Token lifetime in minutes (default: 480 = 8 hours).
AUTH_TOKEN_TTL_MINUTES=480

# ── Database (Neon Serverless Postgres) ───────────────────────
# Local:  postgresql://postgres:postgres@localhost:5432/treasury_os
# Neon:   postgresql://neondb_owner:<password>@ep-xxx.us-east-2.aws.neon.tech/neondb?pgbouncer=true&sslmode=require
DATABASE_URL=<your-database-url>
DATABASE_SSL=<true-or-false>

# ── Redis / Queue (Upstash Serverless Redis) ──────────────────
# Local:  redis://localhost:6379
# Upstash REST API (recommended for cloud):
UPSTASH_REDIS_REST_URL=<your-upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-redis-rest-token>
# Legacy TCP fallback (local dev only):
REDIS_URL=<your-redis-url>
REDIS_QUEUE_ENABLED=<true-or-false>
REDIS_QUEUE_NAME=<your-redis-queue-name>

# ── Dashboard (Vercel) ─────────────────────────────────────────
# Set on Vercel as a server-side env var (NOT NEXT_PUBLIC_):
# Production example: API_BASE_URL=https://api.treasuryos.aicustombot.net/api
API_BASE_URL=https://api.example.up.railway.app/api
# The dashboard also reads the shared KYC_SUMSUB_ENABLED flag defined below.
# Demo access is optional and only works when all three values are set.
DEMO_ACCESS_ENABLED=false
DEMO_ACCESS_EMAIL=<your-demo-access-email>
DEMO_ACCESS_PASSWORD=<your-demo-access-password>

# ── CORS ──────────────────────────────────────────────────────
# The deployed Vercel URL for the dashboard:
FRONTEND_URL=https://dashboard.example.vercel.app

# ── Sentry Error Tracking (optional) ─────────────────────────
# [OPTIONAL] Server-side DSN for the API gateway / Next.js server:
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# [OPTIONAL] Client-side DSN for the Next.js browser bundle:
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Default Seed Users ────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=<your-admin-email>
DEFAULT_ADMIN_PASSWORD=<your-admin-password>
DEFAULT_COMPLIANCE_EMAIL=<your-compliance-email>
DEFAULT_COMPLIANCE_PASSWORD=<your-compliance-password>
DEFAULT_AUDITOR_EMAIL=<your-auditor-email>
DEFAULT_AUDITOR_PASSWORD=<your-auditor-password>

# ── Pilot / Institutional Config ──────────────────────────────
PILOT_REPORTS_DIR=<your-pilot-reports-dir>
PILOT_INSTITUTION_ID=<your-pilot-institution-id>
PILOT_INSTITUTION_NAME=<your-pilot-institution-name>
PILOT_CUSTOMER_PROFILE=<your-pilot-customer-profile>

# ── KYC (SumSub) ─────────────────────────────────────────────
# [OPTIONAL] Enable the live Sumsub KYC workflow. Defaults to false until production is ready.
KYC_SUMSUB_ENABLED=false
# [OPTIONAL] Required only when KYC_SUMSUB_ENABLED=true.
SUMSUB_APP_TOKEN=<your-sumsub-app-token>
SUMSUB_SECRET_KEY=<your-sumsub-secret-key>
SUMSUB_LEVEL_NAME=<your-sumsub-level-name>
SUMSUB_WEBHOOK_SECRET=<your-sumsub-webhook-secret>

# ── Solana ────────────────────────────────────────────────────
SOLANA_RPC_URL=<your-solana-rpc-url>
# Optional network label for services that use shared RPC config helpers.
# Defaults to devnet when omitted.
SOLANA_NETWORK=<your-solana-network>
PROGRAM_ID_WALLET_WHITELIST=<your-program-id>
# For local dev or mounted secret files:
AUTHORITY_KEYPAIR_PATH=<your-authority-keypair-path>
# For Railway-style secret injection (same JSON array format as Solana CLI keypair files):
AUTHORITY_KEYPAIR_JSON=<your-authority-keypair-json>
SOLANA_SIGNING_MODE=<filesystem-or-environment>
SOLANA_SYNC_ENABLED=<true-or-false>

# ── Squads Multisig (optional) ────────────────────────────────
SQUADS_MULTISIG_ENABLED=<true-or-false>
# SQUADS_MULTISIG_ADDRESS=
# Supabase
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
SUPABASE_SERVICE_KEY=<your-supabase-service-key>
SUPABASE_STORAGE_BUCKET=<your-storage-bucket>
SUPABASE_URL=<your-supabase-url>
