# Shared
NODE_ENV=development

# API Gateway
API_GATEWAY_PORT=3001
AUTH_TOKEN_SECRET=replace-with-a-32-char-secret
AUTH_TOKEN_TTL_MINUTES=480
PILOT_DATA_FILE=data/pilot-store.json
PILOT_REPORTS_DIR=data/reports
PILOT_INSTITUTION_ID=pilot-eu-casp
PILOT_INSTITUTION_NAME=TreasuryOS Pilot Institution
PILOT_CUSTOMER_PROFILE=eu-regulated-casp
DEFAULT_ADMIN_EMAIL=admin@treasuryos.local
DEFAULT_ADMIN_PASSWORD=change-me-admin
DEFAULT_COMPLIANCE_EMAIL=compliance@treasuryos.local
DEFAULT_COMPLIANCE_PASSWORD=change-me-compliance
DEFAULT_AUDITOR_EMAIL=auditor@treasuryos.local
DEFAULT_AUDITOR_PASSWORD=change-me-auditor

# KYC Service
KYC_SERVICE_PORT=3002
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_WEBHOOK_SECRET=

# Bank Adapter
BANK_ADAPTER_PORT=3003
AMINA_API_KEY=
AMINA_API_URL=https://api.aminabank.example/v1
SWIFT_BIC=
SWIFT_ALLIANCE_GATEWAY_URL=
SWIFT_PKI_CERT_PATH=

# Reporter
REPORTER_PORT=3004

# Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
PROGRAM_ID_COMPLIANCE_REGISTRY=4nCYGjuX9xj9htmWL3GPAjFkctmHcWVhqTKHXVxnccjS
PROGRAM_ID_WALLET_WHITELIST=FXFMG4hzBcuRu33mVXyTHESH7FnsmUD6Fajr17FugbRt
PROGRAM_ID_TX_MONITOR=5hBm1PqjMcUKJ2rUF1FBjqYPf1nCExaNVmYt8KZSJd65
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json
SOLANA_SYNC_ENABLED=false

# Persistence
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/treasury_os
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_ENABLED=true
REDIS_QUEUE_NAME=treasuryos:events

# ── Supabase (drop-in replacement) ──────────────────────────
# To use Supabase instead of a local Postgres, replace DATABASE_URL:
#   DATABASE_URL=postgresql://postgres.[YOUR-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   DATABASE_SSL=true
# Get these values from: Supabase Dashboard → Settings → Database → Connection string (URI)
