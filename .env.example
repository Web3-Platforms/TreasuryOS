# ═══════════════════════════════════════════════════════════════
# TreasuryOS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in values for your target environment.

# ── Shared ────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (Neon Serverless Postgres) ───────────────────────
# Local:  postgresql://postgres:postgres@localhost:5432/treasury_os
# Neon:   postgresql://neondb_owner:<password>@ep-xxx.us-east-2.aws.neon.tech/neondb?pgbouncer=true&sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/treasury_os
DATABASE_SSL=false

# ── Redis / Queue (Upstash Serverless Redis) ──────────────────
# Local:  redis://localhost:6379
# Upstash REST API (recommended for cloud):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy TCP fallback (local dev only):
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_ENABLED=true
REDIS_QUEUE_NAME=treasuryos:events

# ── API Gateway ───────────────────────────────────────────────
# Railway injects PORT automatically; API_GATEWAY_PORT is the local fallback.
API_GATEWAY_PORT=3001
AUTH_TOKEN_SECRET=replace-with-a-32-char-secret-minimum
AUTH_TOKEN_TTL_MINUTES=480

# ── Frontend → API Mapping ────────────────────────────────────
# Set on Vercel as a server-side env var (NOT NEXT_PUBLIC_):
#   API_BASE_URL=https://your-api.up.railway.app/api
API_BASE_URL=http://localhost:3001/api

# ── CORS (set on Railway) ────────────────────────────────────
# The deployed Vercel URL for the dashboard:
FRONTEND_URL=http://localhost:3000

# ── Default Seed Users ────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@treasuryos.local
DEFAULT_ADMIN_PASSWORD=change-me-admin
DEFAULT_COMPLIANCE_EMAIL=compliance@treasuryos.local
DEFAULT_COMPLIANCE_PASSWORD=change-me-compliance
DEFAULT_AUDITOR_EMAIL=auditor@treasuryos.local
DEFAULT_AUDITOR_PASSWORD=change-me-auditor

# ── Pilot / Institutional Config ──────────────────────────────
PILOT_REPORTS_DIR=data/reports
PILOT_INSTITUTION_ID=pilot-eu-casp
PILOT_INSTITUTION_NAME=TreasuryOS Pilot Institution
PILOT_CUSTOMER_PROFILE=eu-regulated-casp

# ── KYC (SumSub) ─────────────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_WEBHOOK_SECRET=

# ── Solana ────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
PROGRAM_ID_WALLET_WHITELIST=FXFMG4hzBcuRu33mVXyTHESH7FnsmUD6Fajr17FugbRt
# For local dev (filesystem keypair):
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json
SOLANA_SIGNING_MODE=filesystem
SOLANA_SYNC_ENABLED=false

# ── AWS KMS (production signing, optional) ────────────────────
# AWS_KMS_KEY_ID=
# AWS_KMS_PUBLIC_KEY=
# AWS_REGION=

# ── Squads Multisig (optional) ────────────────────────────────
SQUADS_MULTISIG_ENABLED=false
# SQUADS_MULTISIG_ADDRESS=
